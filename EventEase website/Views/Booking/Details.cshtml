@model EventEase_website.Models.BookingM

@{
    ViewData["Title"] = "Booking Details";
}

<style>
    /* ── Page wrapper ── */
    .booking-page {
        max-width: 520px;
        margin: 2.5rem auto;
        padding: 0 1rem;
        font-family: Arial, sans-serif;
    }


        .booking-page h1 {
            font-size: 26px;
            font-weight: bold;
            color: #4A3535;
            margin-bottom: 0.25rem;
        }

        .booking-page .page-subtitle {
            font-size: 13px;
            color: #7A6060;
            margin-bottom: 1.5rem;
        }

        .booking-page hr {
            border: none;
            border-top: 2px solid #C4A882;
            margin-bottom: 1.8rem;
        }

    /* ── Card container ── */
    .booking-card {
        background: #FFFDF8;
        border: 1px solid #D4BFA8;
        border-radius: 12px;
        padding: 2rem 2rem 1.5rem;
        box-shadow: 0 4px 16px rgba(107, 79, 79, 0.10);
        margin-bottom: 1.5rem;
    }

    /* ── Detail table ── */
    .detail-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }

        .detail-table tr {
            border-bottom: 1px solid #EAE3D2;
        }

            .detail-table tr:last-child {
                border-bottom: none;
            }

        .detail-table dt {
            font-weight: bold;
            color: #4A3535;
            font-size: 13px;
            padding: 0.75rem 1rem 0.75rem 0;
            width: 38%;
            vertical-align: top;
            letter-spacing: 0.2px;
        }

        .detail-table dd {
            color: #2C2020;
            font-size: 14px;
            padding: 0.75rem 0;
            margin: 0;
            vertical-align: top;
        }

    /* ── Action row ── */
    .action-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-top: 0.5rem;
    }

    /* ── Edit button ── */
    .btn-edit {
        display: inline-block;
        background: #6B4F4F;
        color: #FFFDF8;
        border: none;
        border-radius: 8px;
        padding: 0.6rem 1.8rem;
        font-size: 14px;
        font-family: Arial, sans-serif;
        font-weight: bold;
        text-decoration: none;
        cursor: pointer;
        transition: background 0.2s, transform 0.1s;
        letter-spacing: 0.3px;
    }

        .btn-edit:hover {
            background: #4A3535;
            color: #FFFDF8;
        }

        .btn-edit:active {
            transform: scale(0.98);
        }

    /* ── Back link ── */
    .back-link {
        display: inline-block;
        font-size: 13px;
        color: #6B4F4F;
        text-decoration: none;
        font-family: Arial, sans-serif;
        transition: color 0.2s;
    }

        .back-link:hover {
            color: #4A3535;
            text-decoration: underline;
        }
</style>

<div class="booking-page">

    <h1>Booking Details</h1>
    <p class="page-subtitle">Viewing details for this booking record.</p>
    <hr />

    <div class="booking-card">
        <dl class="detail-table">
            <tr>
                <dt>@Html.DisplayNameFor(model => model.Event)</dt>
                <dd>@Html.DisplayFor(model => model.Event.EventName)</dd>
            </tr>
            <tr>
                <dt>@Html.DisplayNameFor(model => model.Venue)</dt>
                <dd>@Html.DisplayFor(model => model.Venue.Location)</dd>
            </tr>
            <tr>
                <dt>@Html.DisplayNameFor(model => model.BookingDate)</dt>
                <dd>@Html.DisplayFor(model => model.BookingDate)</dd>
            </tr>
        </dl>
    </div>

    <div class="action-row">
        <a asp-action="Edit" asp-route-id="@Model?.BookingID" class="btn-edit">✎ Edit</a>
        <a asp-action="Index" class="back-link">← Back to List</a>
    </div>

</div>