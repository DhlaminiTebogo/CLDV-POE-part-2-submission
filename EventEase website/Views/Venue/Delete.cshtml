@model EventEase_website.Models.VenueM

@{
    ViewData["Title"] = "Delete Venue";
}

<style>
    /* ── Page wrapper ── */
    .delete-page {
        max-width: 960px;
        margin: 2.5rem auto;
        padding: 0 1rem;
        font-family: Arial, sans-serif;
    }

        .delete-page h1 {
            font-size: 26px;
            font-weight: bold;
            color: #4A3535;
            margin-bottom: 0.25rem;
        }

        .delete-page .page-subtitle {
            font-size: 13px;
            color: #7A6060;
            margin-bottom: 1.5rem;
        }

        .delete-page hr {
            border: none;
            border-top: 2px solid #C4A882;
            margin-bottom: 1.8rem;
        }

    /* ── Warning message ── */
    .warning-message {
        background: #FAF0F0;
        border-left: 4px solid #8B3A3A;
        padding: 1rem 1.25rem;
        border-radius: 8px;
        margin-bottom: 1.5rem;
    }

        .warning-message h3 {
            font-size: 16px;
            font-weight: bold;
            color: #8B3A3A;
            margin: 0;
        }

    /* ── Delete card ── */
    .delete-card {
        background: #FFFDF8;
        border: 1px solid #D4BFA8;
        border-radius: 12px;
        box-shadow: 0 4px 16px rgba(107, 79, 79, 0.10);
        padding: 2rem;
        margin-bottom: 1.5rem;
    }

    /* ── Definition list (dt/dd) styling ── */
    .details-list {
        margin: 0;
    }

    .details-row {
        display: flex;
        flex-direction: column;
        margin-bottom: 1.25rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid #E8DDD0;
    }

        .details-row:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }

    .details-label {
        font-size: 12px;
        font-weight: bold;
        color: #7A6060;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.35rem;
    }

    .details-value {
        font-size: 16px;
        color: #2C2020;
        font-weight: normal;
        word-break: break-word;
    }

    /* ── Image display ── */
    .venue-image {
        margin-top: 0.5rem;
        border-radius: 8px;
        overflow: hidden;
        max-width: 100%;
    }

        .venue-image img {
            max-width: 100%;
            max-height: 300px;
            border-radius: 8px;
            object-fit: cover;
            border: 1px solid #D4BFA8;
        }

    .no-image {
        color: #A08080;
        font-style: italic;
        font-size: 14px;
    }

    /* ── Action buttons ── */
    .action-links {
        display: flex;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .btn-delete {
        display: inline-block;
        background: #8B3A3A;
        color: #FFFDF8;
        border: none;
        border-radius: 8px;
        padding: 0.6rem 1.6rem;
        font-size: 14px;
        font-family: Arial, sans-serif;
        font-weight: bold;
        cursor: pointer;
        transition: background 0.2s, transform 0.1s;
    }

        .btn-delete:hover {
            background: #6B2E2E;
        }

        .btn-delete:active {
            transform: scale(0.98);
        }

    .cancel-link {
        display: inline-block;
        font-size: 13px;
        color: #6B4F4F;
        text-decoration: none;
        font-weight: bold;
        transition: color 0.2s;
    }

        .cancel-link:hover {
            color: #4A3535;
            text-decoration: underline;
        }
</style>

<div class="delete-page">
    <h1>Delete Venue</h1>
    <p class="page-subtitle">Permanently remove this venue from the system.</p>
    <hr />

    <div class="warning-message">
        <h3>⚠ Are you sure you want to delete this venue?</h3>
    </div>

    <div class="delete-card">
        <dl class="details-list">
            <div class="details-row">
                <dt class="details-label">@Html.DisplayNameFor(model => model.VenueName)</dt>
                <dd class="details-value">@Html.DisplayFor(model => model.VenueName)</dd>
            </div>

            <div class="details-row">
                <dt class="details-label">@Html.DisplayNameFor(model => model.Location)</dt>
                <dd class="details-value">@Html.DisplayFor(model => model.Location)</dd>
            </div>

            <div class="details-row">
                <dt class="details-label">@Html.DisplayNameFor(model => model.Capacity)</dt>
                <dd class="details-value">@Html.DisplayFor(model => model.Capacity)</dd>
            </div>

            <div class="details-row">
                <dt class="details-label">@Html.DisplayNameFor(model => model.ImageUrl)</dt>
                <dd class="details-value">
                    @if (!string.IsNullOrEmpty(Model?.ImageUrl))
                    {
                        <div class="venue-image">
                            <img src="@Model.ImageUrl" alt="@Model.VenueName" onerror="this.onerror=null; this.style.display='none'; this.nextElementSibling.style.display='block';" />
                            <span style="display:none;" class="no-image">Image could not be loaded</span>
                        </div>
                    }
                    else
                    {
                        <span class="no-image">No image available</span>
                    }
                </dd>
            </div>
        </dl>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="VenueID" />
        <div class="action-links">
            <input type="submit" value="Delete Permanently" class="btn-delete" />
            <a asp-action="Index" class="cancel-link">← Cancel & Back to Venues</a>
        </div>
    </form>
</div>