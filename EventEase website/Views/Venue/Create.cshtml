@model EventEase_website.Models.VenueM

@{
    ViewData["Title"] = "Create Venue";
}

<style>
    /* ── Page wrapper ── */
    .create-page {
        max-width: 960px;
        margin: 2.5rem auto;
        padding: 0 1rem;
        font-family: Arial, sans-serif;
    }

        .create-page h1 {
            font-size: 26px;
            font-weight: bold;
            color: #4A3535;
            margin-bottom: 0.25rem;
        }

        .create-page .page-subtitle {
            font-size: 13px;
            color: #7A6060;
            margin-bottom: 1.5rem;
        }

        .create-page hr {
            border: none;
            border-top: 2px solid #C4A882;
            margin-bottom: 1.8rem;
        }

    /* ── Form card ── */
    .form-card {
        background: #FFFDF8;
        border: 1px solid #D4BFA8;
        border-radius: 12px;
        box-shadow: 0 4px 16px rgba(107, 79, 79, 0.10);
        padding: 2rem 2.5rem;
        max-width: 520px;
    }

    /* ── Form groups ── */
    .form-group {
        display: flex;
        flex-direction: column;
        margin-bottom: 1.2rem;
    }

        .form-group label {
            font-size: 13px;
            font-weight: bold;
            color: #4A3535;
            margin-bottom: 0.35rem;
            letter-spacing: 0.2px;
        }

        .form-group input {
            font-family: Arial, sans-serif;
            font-size: 14px;
            color: #2C2020;
            background: #FDFAF4;
            border: 1px solid #C4A882;
            border-radius: 8px;
            padding: 0.55rem 0.85rem;
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
            width: 100%;
            box-sizing: border-box;
        }

            .form-group input:focus {
                border-color: #6B4F4F;
                box-shadow: 0 0 0 3px rgba(107, 79, 79, 0.12);
            }

    /* ── Image URL preview ── */
    .image-preview-box {
        margin-top: 0.6rem;
        border: 1px dashed #C4A882;
        border-radius: 8px;
        background: #FAF7F2;
        padding: 0.5rem;
        text-align: center;
        min-height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

        .image-preview-box img {
            max-height: 120px;
            max-width: 100%;
            border-radius: 6px;
            object-fit: cover;
            display: none;
        }

        .image-preview-box .preview-placeholder {
            font-size: 12px;
            color: #A08080;
        }

    /* ── Validation ── */
    .field-validation-error {
        font-size: 12px;
        color: #8B2020;
        margin-top: 0.3rem;
    }

    .validation-summary-errors {
        font-size: 13px;
        color: #8B2020;
        background: #FAF0F0;
        border: 1px solid #E8C4C4;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        margin-bottom: 1.2rem;
    }

    /* ── Submit button ── */
    .btn-create {
        display: inline-block;
        background: #6B4F4F;
        color: #FFFDF8;
        border: none;
        border-radius: 8px;
        padding: 0.6rem 1.6rem;
        font-size: 14px;
        font-family: Arial, sans-serif;
        font-weight: bold;
        cursor: pointer;
        letter-spacing: 0.3px;
        transition: background 0.2s, transform 0.1s;
    }

        .btn-create:hover {
            background: #4A3535;
        }

        .btn-create:active {
            transform: scale(0.98);
        }

    /* ── Back link ── */
    .back-link {
        display: inline-block;
        margin-top: 1.2rem;
        font-size: 13px;
        color: #6B4F4F;
        text-decoration: none;
        font-weight: bold;
        transition: color 0.2s;
    }

        .back-link:hover {
            color: #4A3535;
            text-decoration: underline;
        }
</style>

<div class="create-page">
    <h1>Create Venue</h1>
    <p class="page-subtitle">Add a new venue to the system.</p>
    <hr />

    <div class="form-card">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <div class="form-group">
                <label asp-for="VenueName"></label>
                <input asp-for="VenueName" />
                <span asp-validation-for="VenueName" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Location"></label>
                <input asp-for="Location" />
                <span asp-validation-for="Location" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Capacity"></label>
                <input asp-for="Capacity" />
                <span asp-validation-for="Capacity" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ImageUrl"></label>
                <input asp-for="ImageUrl" id="imageUrlInput" />
                <span asp-validation-for="ImageUrl" class="field-validation-error"></span>
                <div class="image-preview-box" id="imagePreviewBox">
                    <img id="imagePreview" src="" alt="Image preview" />
                    <span class="preview-placeholder" id="previewPlaceholder">
                        Image preview will appear here
                    </span>
                </div>
            </div>

            <div class="form-group" style="margin-top: 1.5rem;">
                <input type="submit" value="Create Venue" class="btn-create" />
            </div>
        </form>
    </div>

    <a asp-action="Index" class="back-link">← Back to Venues</a>
</div>

<script>
    // Live image URL preview
    const input = document.getElementById('imageUrlInput');
    const preview = document.getElementById('imagePreview');
    const placeholder = document.getElementById('previewPlaceholder');

    function updatePreview(url) {
        if (url && url.trim() !== '') {
            preview.src = url.trim();
            preview.style.display = 'block';
            placeholder.style.display = 'none';
            preview.onerror = function () {
                preview.style.display = 'none';
                placeholder.style.display = 'block';
                placeholder.textContent = 'Could not load image from this URL';
            };
        } else {
            preview.style.display = 'none';
            placeholder.style.display = 'block';
            placeholder.textContent = 'Image preview will appear here';
        }
    }

    // Update on input change
    input.addEventListener('input', function () {
        updatePreview(this.value);
    });
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}