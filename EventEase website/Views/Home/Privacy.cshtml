@{
    ViewData["Title"] = "Privacy Policy";
}

<style>
    /* ── Page wrapper ── */
    .privacy-page {
        max-width: 960px;
        margin: 2.5rem auto;
        padding: 0 1rem;
        font-family: Arial, sans-serif;
    }

        .privacy-page h1 {
            font-size: 32px;
            font-weight: bold;
            color: #4A3535;
            margin-bottom: 0.25rem;
        }

        .privacy-page .last-updated {
            font-size: 13px;
            color: #7A6060;
            margin-bottom: 1.5rem;
        }

        .privacy-page hr {
            border: none;
            border-top: 2px solid #C4A882;
            margin-bottom: 1.8rem;
        }

    /* ── Content card ── */
    .privacy-card {
        background: #FFFDF8;
        border: 1px solid #D4BFA8;
        border-radius: 12px;
        box-shadow: 0 4px 16px rgba(107, 79, 79, 0.10);
        padding: 2rem 2rem;
    }

    .privacy-section {
        margin-bottom: 1.8rem;
    }

        .privacy-section:last-child {
            margin-bottom: 0;
        }

        .privacy-section h2 {
            font-size: 20px;
            font-weight: bold;
            color: #4A3535;
            margin-bottom: 0.75rem;
        }

        .privacy-section p {
            font-size: 14px;
            color: #2C2020;
            line-height: 1.5;
            margin-bottom: 0.75rem;
        }

        .privacy-section ul {
            margin: 0.5rem 0 0.5rem 1.5rem;
            padding: 0;
        }

        .privacy-section li {
            font-size: 14px;
            color: #2C2020;
            line-height: 1.5;
            margin-bottom: 0.25rem;
        }

    .contact-info {
        background: #FAF7F2;
        border-left: 3px solid #6B4F4F;
        padding: 1rem 1.25rem;
        border-radius: 8px;
        margin-top: 1rem;
    }

        .contact-info p {
            margin: 0;
            font-size: 14px;
            color: #4A3535;
        }
</style>

<div class="privacy-page">
    <h1>Privacy Policy</h1>
    <p class="last-updated">Last updated: April 2026</p>
    <hr />

    <div class="privacy-card">
        <div class="privacy-section">
            <h2>Information We Collect</h2>
            <p>EventEase collects only the information you provide directly when using our platform:</p>
            <ul>
                <li><strong>Venue Information:</strong> Venue names, locations, capacities, and images you upload</li>
                <li><strong>Event Information:</strong> Event details you create and manage</li>
                <li><strong>Account Information:</strong> Basic information needed to manage your account</li>
            </ul>
        </div>

        <div class="privacy-section">
            <h2>How We Use Your Information</h2>
            <p>We use the information collected to:</p>
            <ul>
                <li>Provide and maintain venue and event management services</li>
                <li>Display venue and event information you have entered</li>
                <li>Improve and optimize our platform</li>
            </ul>
        </div>

        <div class="privacy-section">
            <h2>Data Storage</h2>
            <p>Your data is stored securely and is only accessible to authorized users of the EventEase platform. We do not share your information with third parties unless required by law.</p>
        </div>

        <div class="privacy-section">
            <h2>Your Choices</h2>
            <p>You can view, edit, or delete your venue and event information at any time through the EventEase dashboard. If you need assistance, please contact us.</p>
        </div>

        <div class="privacy-section">
            <h2>Contact Us</h2>
            <div class="contact-info">
                <p>📧 Email: privacy@eventease.com</p>
                <p>📍 Address: 123 Management Street, Business District</p>
            </div>
        </div>
    </div>
</div>