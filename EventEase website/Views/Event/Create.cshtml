@model EventEase_website.Models.EventM

@{
    ViewData["Title"] = "Create Event";
}

<style>
    /* ── Page wrapper ── */
    .create-page {
        max-width: 960px;
        margin: 2.5rem auto;
        padding: 0 1rem;
        font-family: Arial, sans-serif;
    }

        .create-page h1 {
            font-size: 26px;
            font-weight: bold;
            color: #4A3535;
            margin-bottom: 0.25rem;
        }

        .create-page .page-subtitle {
            font-size: 13px;
            color: #7A6060;
            margin-bottom: 1.5rem;
        }

        .create-page hr {
            border: none;
            border-top: 2px solid #C4A882;
            margin-bottom: 1.8rem;
        }

    /* ── Form card ── */
    .form-card {
        background: #FFFDF8;
        border: 1px solid #D4BFA8;
        border-radius: 12px;
        box-shadow: 0 4px 16px rgba(107, 79, 79, 0.10);
        padding: 2rem 2.5rem;
        max-width: 520px;
    }

    /* ── Form groups ── */
    .form-group {
        display: flex;
        flex-direction: column;
        margin-bottom: 1.2rem;
    }

        .form-group label {
            font-size: 13px;
            font-weight: bold;
            color: #4A3535;
            margin-bottom: 0.35rem;
            letter-spacing: 0.2px;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            font-family: Arial, sans-serif;
            font-size: 14px;
            color: #2C2020;
            background: #FDFAF4;
            border: 1px solid #C4A882;
            border-radius: 8px;
            padding: 0.55rem 0.85rem;
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

            .form-group input:focus,
            .form-group select:focus,
            .form-group textarea:focus {
                border-color: #6B4F4F;
                box-shadow: 0 0 0 3px rgba(107, 79, 79, 0.12);
            }

    /* ── Validation ── */
    .field-validation-error {
        font-size: 12px;
        color: #8B2020;
        margin-top: 0.3rem;
    }

    .validation-summary-errors {
        font-size: 13px;
        color: #8B2020;
        background: #FAF0F0;
        border: 1px solid #E8C4C4;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        margin-bottom: 1.2rem;
    }

    /* ── Submit button ── */
    .btn-submit {
        display: inline-block;
        background: #6B4F4F;
        color: #FFFDF8;
        border: none;
        border-radius: 8px;
        padding: 0.6rem 1.6rem;
        font-size: 14px;
        font-family: Arial, sans-serif;
        font-weight: bold;
        cursor: pointer;
        letter-spacing: 0.3px;
        transition: background 0.2s, transform 0.1s;
    }

        .btn-submit:hover {
            background: #4A3535;
        }

        .btn-submit:active {
            transform: scale(0.98);
        }

    /* ── Back link ── */
    .back-link {
        display: inline-block;
        margin-top: 1.2rem;
        font-size: 13px;
        color: #6B4F4F;
        text-decoration: none;
        font-weight: bold;
        transition: color 0.2s;
    }

        .back-link:hover {
            color: #4A3535;
            text-decoration: underline;
        }
</style>

<div class="create-page">

    <h1>Create Event</h1>
    <p class="page-subtitle">Fill in the details below to schedule a new event.</p>
    <hr />

    <div class="form-card">

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <div class="form-group">
                <label asp-for="EventName"></label>
                <input asp-for="EventName" />
                <span asp-validation-for="EventName" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="EventDate"></label>
                <input asp-for="EventDate" />
                <span asp-validation-for="EventDate" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description"></label>
                <input asp-for="Description" />
                <span asp-validation-for="Description" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="VenueID"></label>
                <select asp-for="VenueID">
                    <option value="">-- Select Venue --</option>
                    @foreach (var venue in ViewBag.Venues)
                    {
                        <option value="@venue.VenueID">@venue.VenueName</option>
                    }
                </select>
                <span asp-validation-for="VenueID" class="field-validation-error"></span>
            </div>

            <div class="form-group" style="margin-top: 1.5rem;">
                <input type="submit" value="Create Event" class="btn-submit" />
            </div>

        </form>

    </div>

    <a asp-action="Index" class="back-link">← Back to Events</a>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}