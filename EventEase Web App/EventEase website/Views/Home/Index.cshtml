@{
    ViewData["Title"] = "Home";
}



<style>
    /* ── Page wrapper ── */
    .home-page {
        max-width: 800px;
        margin: 3rem auto;
        padding: 0 1rem;
        font-family: Arial, sans-serif;
        text-align: center;
    }

    /* ── Hero section ── */
    .hero-section {
        background: #FFFDF8;
        border-radius: 16px;
        border: 1px solid #D4BFA8;
        box-shadow: 0 4px 16px rgba(107, 79, 79, 0.08);
        padding: 3rem 2rem;
    }

        .hero-section h1 {
            font-size: 48px;
            font-weight: bold;
            color: #4A3535;
            margin-bottom: 0.5rem;
        }

        .hero-section .tagline {
            font-size: 18px;
            color: #7A6060;
            margin-bottom: 1.5rem;
        }

        .hero-section hr {
            border: none;
            border-top: 2px solid #C4A882;
            width: 60px;
            margin: 1.5rem auto;
        }

    .hero-description {
        font-size: 16px;
        color: #2C2020;
        line-height: 1.6;
        max-width: 550px;
        margin: 0 auto;
    }
</style>

<div class="home-page">
    <div class="hero-section">
        <h1>EventEase</h1>
        <p class="tagline">Simple venue and event management</p>
        <hr />
        <p class="hero-description">
            EventEase helps you manage venues and organize events in one clean,
            easy-to-use platform. Keep track of locations, capacities, and event
            details — all in one place.
        </p>
    </div>
</div>